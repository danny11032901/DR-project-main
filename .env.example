APP_NAME=RetinaIQ
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000

SECRET_KEY=replace-with-256-bit-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DB_HOST=postgres
DB_PORT=5432
DB_NAME=retinaiq
DB_USER=retinaiq_user
DB_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=retinaiq-images
MINIO_SECURE=false

# AWS S3 Configuration (for Render/production)
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

MODEL_DIR=/app/ml_models
DEFAULT_MODEL_TIER=2
AUTO_TRAIN_IF_MISSING=true
DATASET_PATH=/app/data/aptos2019
TRAIN_ON_START_EPOCHS=5
TRAIN_ON_START_BATCH_SIZE=16
EFFICIENTNETV2B3_WEIGHTS=retinaiq_efficientnetv2b3.h5
EFFICIENTNETB0_WEIGHTS=retinaiq_efficientnetb0.h5
MOBILENETV3_WEIGHTS=retinaiq_mobilenetv3.h5
DENSENET121_WEIGHTS=retinaiq_densenet121.h5
IMAGE_QUALITY_THRESHOLD=40
MAX_UPLOAD_SIZE_MB=20

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

LOG_LEVEL=INFO
LOG_FORMAT=json
